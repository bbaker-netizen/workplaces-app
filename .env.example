# ============================================================
# The Builder — environment variables
# ============================================================
# Copy this file to `.env.local` and fill in real values for
# local development. `.env.local` is git-ignored.
#
# For production, set these in the Netlify dashboard:
# https://app.netlify.com/projects/<project>/configuration/env
# ============================================================

# ---- Database (Neon Postgres) -------------------------------
# Pooled connection string from console.neon.tech. The host
# segment must include "-pooler" — Netlify's serverless functions
# need PgBouncer-style pooling, not a direct pg connection.
# Format: postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
DATABASE_URL=

# ---- Auth (Clerk) -------------------------------------------
# From dashboard.clerk.com → API Keys for the active environment.
# `pk_test_…` for development, `pk_live_…` once we promote.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Webhook signing secret. Create at
# https://dashboard.clerk.com/last-active/webhooks → Add endpoint
# pointing at https://workplaces-the-builder.netlify.app/api/webhooks/clerk
# subscribed to user.created, organizationMembership.created,
# organizationMembership.deleted, organization.deleted.
CLERK_WEBHOOK_SECRET=

# Clerk redirects. The "fallback" variants are used when there's no
# explicit `?redirect_url=` query param (i.e., direct visits to /sign-in).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/portal
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/portal

# ---- AI (Anthropic Claude) ----------------------------------
# From console.anthropic.com → API Keys. Used by Generate buttons
# and Soul File RAG. Server-only — never prefix with NEXT_PUBLIC.
ANTHROPIC_API_KEY=

# ---- Email (Resend) -----------------------------------------
# From resend.com → API Keys. Sending domain must be verified in
# Resend's dashboard before a key issued here will deliver mail.
# Server-only — never prefix with NEXT_PUBLIC.
RESEND_API_KEY=
# Display name + address. Format: `Display Name <local@domain>`.
# Example: The Builder <notifications@4workplaces.com>
RESEND_FROM_EMAIL=

# Public web origin used in email templates' link buttons.
# Local dev: http://localhost:3000
# Netlify production: https://workplaces-the-builder.netlify.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Bearer secret guarding /api/cron/* endpoints. The Netlify scheduled
# function (`netlify/functions/email-due-soon.mts`) re-uses this value
# to authenticate its self-fetch. Generate any random 32-byte string.
CRON_SECRET=

# ---- MCP server (Workplaces plugin in Cowork) ---------------
# Bearer secret guarding /api/mcp. The Workplaces plugin in Cowork
# holds this secret in its config; it pairs the secret with a coach's
# clerk_user_id like `Bearer <SECRET>:<clerk_user_id>` to call MCP
# tools on behalf of that coach. Generate any random 32-byte string.
MCP_BEARER_TOKEN=

# ---- Fireflies (transcript ingest → action item drafts) -----
# From https://app.fireflies.ai/settings/developer-portal.
FIREFLIES_API_KEY=

# ---- Stripe (subscription billing) -------------------------
# From https://dashboard.stripe.com/apikeys. Server-only secret —
# never prefix with NEXT_PUBLIC.
STRIPE_SECRET_KEY=
# From https://dashboard.stripe.com/webhooks → Add endpoint pointing
# at https://workplaces-the-builder.netlify.app/api/webhooks/stripe
# subscribed to invoice.created / updated / finalized / paid /
# payment_failed / voided.
STRIPE_WEBHOOK_SECRET=

# ---- Netlify API (read-only — for Embedded Apps picker) -----
# Personal access token from
# https://app.netlify.com/user/applications#personal-access-tokens
# Used to list Netlify projects in the Embedded Apps registration UI.
NETLIFY_PERSONAL_ACCESS_TOKEN=

# ---- File storage (Netlify Blobs) ---------------------------
# Production on Netlify auto-detects credentials — no setup needed.
# Local dev works either via `netlify dev` (Netlify CLI manages auth)
# OR by providing the two values below. Get them from:
# https://app.netlify.com/user/applications  (Personal access token)
# Site ID is on Site Configuration → General → Site information.
NETLIFY_BLOBS_SITE_ID=
NETLIFY_BLOBS_TOKEN=
